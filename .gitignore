# =============================================
# ALIF ASSOCIATES — .gitignore
# Static HTML website — minimal ignore rules
# =============================================

# ── OS FILES ──────────────────────────────────
# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Icon?

# Windows
Thumbs.db
Thumbs.db:encdata
Desktop.ini
ehthumbs.db
ehthumbs_vista.db
$RECYCLE.BIN/

# Linux
*~

# ── EDITOR & IDE FILES ────────────────────────
# VS Code
.vscode/
*.code-workspace

# JetBrains (WebStorm, PhpStorm, etc.)
.idea/
*.iml
*.iws

# Sublime Text
*.sublime-workspace
*.sublime-project

# Vim / Neovim
*.swp
*.swo
*.swn
.netrwhist

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock

# ── NODE / NPM (if ever added) ────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnp/
.pnp.js
package-lock.json
yarn.lock

# ── BUILD OUTPUTS (if ever added) ─────────────
dist/
build/
out/
.output/
.cache/
.temp/
tmp/

# ── ENVIRONMENT & SECRETS ─────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.env
secrets.json
config.local.js

# ── CLOUDFLARE SPECIFIC ───────────────────────
.wrangler/
.dev.vars

# ── BACKUP & TEMP FILES ───────────────────────
*.bak
*.backup
*.old
*.orig
*.tmp
*.log
*-backup.html
*-old.html
*-copy.html
draft-*.html

# ── CERTIFICATES & KEYS ───────────────────────
*.pem
*.key
*.cert
*.crt

# ── UPLOADED ASSETS (keep originals local) ────
# Uncomment if you ever add an assets folder
# /assets/uploads/
# /images/uploads/

# ── ANALYTICS & TRACKING (keep local) ─────────
analytics-export*.csv
ga-export*.json
